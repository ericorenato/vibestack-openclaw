.env
*.local
.DS_Store
node_modules/
*.zip

# Override LOCAL do compose (ajustes por maquina: GPU, portas extras, etc.).
# O docker-compose.yml e' o modelo versionado; este sobrepoe so' na maquina local.
docker-compose.override.yml

# openclaw.json da raiz e' a config real (copiada da VPS, contem secrets).
# O template versionado fica em config/openclaw.json.
/openclaw.json
/openclaw.json.bak*

# agency/ = templates de prompt dos agentes (IDENTITY/SOUL/USER/TOOLS/AGENTS).
# SÃO versionados (alunos baixam, trocam os {{placeholders}} e carregam no OpenClaw).
# Só ignoramos artefatos de RUNTIME que o OpenClaw porventura escreva aqui:
/agency/**/sessions/
/agency/**/sandbox/
/agency/**/.runtime/

# Artefatos de criativo (imagens/vídeos gerados, seed do rosto, referências, validados)
# usados/produzidos localmente pela gestão de ads — NÃO versionar (pesados + pessoais).
/agency/gerado/
/agency/seed/
/agency/validado/
/agency/referencia/

# guia do curso Hermes — nao versionar
/docs/curso-hermes.md
