# Normaliza fim de linha no checkout. Scripts shell PRECISAM ser LF: com CRLF
# o shebang vira "#!/bin/sh\r" e o container falha com "entrypoint not found".
* text=auto
*.sh text eol=lf
entrypoint.sh text eol=lf
install.sh text eol=lf
# Scripts sem extensao em scripts/ (start-ollama, start-lmstudio, models-status)
# tambem PRECISAM ser LF — rodam no container Linux.
scripts/* text eol=lf
